# Database Configuration (MariaDB)
DB_HOST=localhost
DB_PORT=3306
DB_USER=chatapp
DB_PASSWORD=chatapp_secret
DB_NAME=chatinterface

# JWT Secret
JWT_SECRET=operator-chat-secret-key-12345

# Server Configuration
PORT=3001

# Llama Configuration
