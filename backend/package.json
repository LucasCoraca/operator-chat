    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.20.0",
    "openai": "^6.29.0",
    "pdf-parse": "^1.1.1",
    "puppeteer": "^24.39.1",
    "socket.io": "^4.6.1",
    "socket.io-client": "^4.8.3",
